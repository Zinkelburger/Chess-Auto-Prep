---
import Base from '../layouts/Base.astro';
---
<Base title="Dashboard">
  <div id="auth-gate" style="text-align:center; padding:60px 0;">
    <h1>Loading dashboard...</h1>
    <p class="subtitle">Authenticating...</p>
  </div>

  <div id="dashboard" style="display:none;">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:32px;">
      <div>
        <h1>Your Subscriptions</h1>
        <p class="subtitle" style="margin-bottom:0;" id="user-email"></p>
      </div>
      <button class="btn btn-primary" id="show-add-form">+ New Subscription</button>
    </div>

    <!-- Add subscription form (hidden by default) -->
    <div id="add-form" class="card" style="display:none; margin-bottom:24px;">
      <h2>New Subscription</h2>
      <div id="add-alert" style="display:none;"></div>
      <form id="sub-form">
        <div class="form-row">
          <label for="dash-sub-label">Label</label>
          <input type="text" id="dash-sub-label" />
        </div>

        <!-- Dynamic filters section -->
        <div class="filters-section">
          <div class="filters-header">
            <span class="filters-title">Filters</span>
            <span class="filters-hint">At least one required</span>
          </div>
          <div id="dash-filters-container"></div>
          <div class="dash-add-filter-wrap">
            <button type="button" class="btn btn-outline btn-sm" id="dash-add-filter-btn">+ Add filter</button>
            <div id="dash-filter-menu" class="filter-menu" style="display:none;"></div>
          </div>
        </div>

        <div class="form-row" style="display:flex; align-items:end; padding-bottom:2px;">
          <label class="checkbox-label">
            <input type="checkbox" id="dash-sub-exclude-chess-com" checked />
            <span>Exclude online games (i.e. chess.com)</span>
          </label>
        </div>

        <div style="display:flex; gap:10px; margin-top:8px;">
          <button type="submit" class="btn btn-primary">Create Subscription</button>
          <button type="button" class="btn btn-outline" id="cancel-add">Cancel</button>
        </div>
      </form>
    </div>

    <!-- Subscription list -->
    <div id="subs-list"></div>

    <div id="empty-state" class="card" style="display:none; text-align:center; padding:48px;">
      <p style="font-size:1.2rem; margin-bottom:8px;">No subscriptions yet</p>
      <p style="color:var(--text-dim); font-size:0.9rem;">
        Click "+ New Subscription" to start tracking positions, players, or openings.
      </p>
    </div>
  </div>
</Base>

<script>
  const API = import.meta.env.PUBLIC_API_URL || 'http://localhost:8000';
  let authToken: string | null = null;

  function authHeaders(extra: Record<string, string> = {}): Record<string, string> {
    return { 'Authorization': `Bearer ${authToken}`, ...extra };
  }

  // ── Dynamic filter system ──────────────────────────────────────────────

  interface FilterDef {
    key: string;
    label: string;
    inputType: string;
    inputMode?: string;
    pattern?: string;
    mono?: boolean;
    hasBoardPreview?: boolean;
  }

  const FILTER_DEFS: FilterDef[] = [
    { key: 'fen', label: 'FEN', inputType: 'text', mono: true, hasBoardPreview: true },
    { key: 'player', label: 'Player name', inputType: 'text' },
    { key: 'eco', label: 'ECO Code', inputType: 'text' },
    { key: 'min_elo', label: 'Minimum Elo', inputType: 'text', inputMode: 'numeric', pattern: '[0-9]*' },
    { key: 'max_elo', label: 'Maximum Elo', inputType: 'text', inputMode: 'numeric', pattern: '[0-9]*' },
    { key: 'event', label: 'Event name', inputType: 'text' },
  ];

  const dashActiveFilters: Set<string> = new Set();
  const dashContainer = document.getElementById('dash-filters-container')!;
  const dashAddBtn = document.getElementById('dash-add-filter-btn')!;
  const dashFilterMenu = document.getElementById('dash-filter-menu')!;

  function dashBuildFilterRow(def: FilterDef): HTMLElement {
    const row = document.createElement('div');
    row.className = 'filter-row';
    row.dataset.filterKey = def.key;

    const body = document.createElement('div');
    body.className = 'filter-body';

    const lbl = document.createElement('label');
    lbl.textContent = def.label;
    lbl.setAttribute('for', `dash-sub-${def.key.replace('_', '-')}`);
    body.appendChild(lbl);

    const input = document.createElement('input');
    input.type = def.inputType;
    input.id = `dash-sub-${def.key.replace('_', '-')}`;
    if (def.mono) input.className = 'mono';
    if (def.inputMode) input.inputMode = def.inputMode;
    if (def.pattern) input.pattern = def.pattern;
    input.autocomplete = 'off';
    body.appendChild(input);

    if (def.hasBoardPreview) {
      const board = document.createElement('div');
      board.id = 'dash-fen-board';
      board.className = 'board-preview';
      body.appendChild(board);
      const err = document.createElement('div');
      err.id = 'dash-fen-error';
      err.className = 'board-invalid';
      body.appendChild(err);
    }

    row.appendChild(body);

    const removeBtn = document.createElement('button');
    removeBtn.type = 'button';
    removeBtn.className = 'filter-remove';
    removeBtn.innerHTML = '&times;';
    removeBtn.title = 'Remove filter';
    removeBtn.addEventListener('click', () => dashRemoveFilter(def.key));
    row.appendChild(removeBtn);

    return row;
  }

  function dashAddFilter(key: string) {
    if (dashActiveFilters.has(key)) return;
    const def = FILTER_DEFS.find(d => d.key === key);
    if (!def) return;

    dashActiveFilters.add(key);
    const row = dashBuildFilterRow(def);
    dashContainer.appendChild(row);

    if (def.hasBoardPreview) {
      const fenInput = document.getElementById('dash-sub-fen') as HTMLInputElement;
      const fenBoard = document.getElementById('dash-fen-board')!;
      const fenError = document.getElementById('dash-fen-error')!;
      fenInput.addEventListener('input', () => (window as any).renderBoardPreview(fenInput.value, fenBoard, fenError));
    }

    dashUpdateMenuState();
    dashHideMenu();
  }

  function dashRemoveFilter(key: string) {
    dashActiveFilters.delete(key);
    const row = dashContainer.querySelector(`[data-filter-key="${key}"]`);
    if (row) row.remove();
    dashUpdateMenuState();
  }

  function dashUpdateMenuState() {
    dashFilterMenu.innerHTML = '';
    let anyAvailable = false;
    for (const def of FILTER_DEFS) {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'filter-menu-item';
      btn.textContent = def.label;
      if (dashActiveFilters.has(def.key)) {
        btn.disabled = true;
      } else {
        anyAvailable = true;
        btn.addEventListener('click', () => dashAddFilter(def.key));
      }
      dashFilterMenu.appendChild(btn);
    }
    dashAddBtn.style.display = anyAvailable ? '' : 'none';
  }

  function dashShowMenu() { dashFilterMenu.style.display = 'block'; }
  function dashHideMenu() { dashFilterMenu.style.display = 'none'; }

  dashAddBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    if (dashFilterMenu.style.display === 'none') {
      dashUpdateMenuState();
      dashShowMenu();
    } else {
      dashHideMenu();
    }
  });

  document.addEventListener('click', (e) => {
    if (!(e.target as Element).closest('.dash-add-filter-wrap')) dashHideMenu();
  });

  dashAddFilter('fen');

  // ── Auth & init ──────────────────────────────────────────────────────

  async function init() {
    const gate = document.getElementById('auth-gate')!;
    const dash = document.getElementById('dashboard')!;
    const params = new URLSearchParams(window.location.search);
    const urlToken = params.get('token');

    if (urlToken) {
      try {
        const res = await fetch(`${API}/api/exchange-token`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ token: urlToken }),
        });
        if (res.ok) {
          const data = await res.json();
          localStorage.setItem('twic_auth_token', data.auth_token);
          authToken = data.auth_token;
          window.history.replaceState({}, '', '/dashboard');
        } else {
          window.history.replaceState({}, '', '/dashboard');
          localStorage.removeItem('twic_auth_token');
          gate.innerHTML = `
            <h1>Link expired</h1>
            <p class="subtitle">This login link has already been used or has expired.</p>
            <a href="/twic-notifications" class="btn btn-primary">Request a new login link</a>`;
          return;
        }
      } catch {
        gate.innerHTML = `
          <div class="alert alert-error">Could not reach the server. Try refreshing the page.</div>`;
        return;
      }
    } else {
      authToken = localStorage.getItem('twic_auth_token');
    }

    if (!authToken) {
      gate.innerHTML = `
        <h1>Not logged in</h1>
        <p class="subtitle">You need a login link to access the dashboard.</p>
        <a href="/twic-notifications" class="btn btn-primary">Go to TWIC Notifications</a>`;
      return;
    }

    try {
      const [subsRes, meRes] = await Promise.all([
        fetch(`${API}/api/subscriptions`, { headers: authHeaders() }),
        fetch(`${API}/api/me`, { headers: authHeaders() }),
      ]);
      if (!subsRes.ok) {
        localStorage.removeItem('twic_auth_token');
        gate.innerHTML = `
          <h1>Session expired</h1>
          <p class="subtitle">Your session has expired.</p>
          <a href="/twic-notifications" class="btn btn-primary">Get a new login link</a>`;
        return;
      }

      gate.style.display = 'none';
      dash.style.display = 'block';

      if (meRes.ok) {
        const meData = await meRes.json();
        document.getElementById('user-email')!.textContent = meData.email;
      }

      const data = await subsRes.json();
      renderSubscriptions(data.subscriptions);
    } catch {
      gate.innerHTML = `
        <div class="alert alert-error">Could not reach the server.</div>
        <a href="/" class="btn btn-primary">Go Home</a>`;
    }
  }

  function renderSubscriptions(subs: any[]) {
    const list = document.getElementById('subs-list')!;
    const empty = document.getElementById('empty-state')!;

    if (subs.length === 0) {
      list.innerHTML = '';
      empty.style.display = 'block';
      return;
    }

    empty.style.display = 'none';
    list.innerHTML = '';

    for (const sub of subs) {
      const card = document.createElement('div');
      card.className = 'card';

      const h3 = document.createElement('h3');
      h3.style.marginBottom = '8px';
      h3.textContent = sub.label || 'Untitled subscription';
      card.appendChild(h3);

      const tagsDiv = document.createElement('div');
      tagsDiv.style.cssText = 'display:flex; flex-wrap:wrap; gap:6px; margin-bottom:12px;';
      const tagEntries: [string, string][] = [];
      if (sub.fen) tagEntries.push(['FEN', sub.fen]);
      if (sub.player) tagEntries.push(['Player', sub.player]);
      if (sub.white) tagEntries.push(['White', sub.white]);
      if (sub.black) tagEntries.push(['Black', sub.black]);
      if (sub.eco) tagEntries.push(['ECO', sub.eco]);
      if (sub.min_elo) tagEntries.push(['Min Elo', String(sub.min_elo)]);
      if (sub.max_elo) tagEntries.push(['Max Elo', String(sub.max_elo)]);
      if (sub.event) tagEntries.push(['Event', sub.event]);
      for (const [label, val] of tagEntries) {
        const tag = document.createElement('span');
        tag.className = 'tag';
        tag.textContent = `${label}: ${val}`;
        tagsDiv.appendChild(tag);
      }
      card.appendChild(tagsDiv);

      const actions = document.createElement('div');
      actions.style.cssText = 'display:flex; gap:8px; align-items:center;';

      const editBtn = document.createElement('button');
      editBtn.className = 'sub-action-btn';
      editBtn.innerHTML = 'Edit &#9998;';
      editBtn.title = 'Edit subscription';
      editBtn.addEventListener('click', () => editSub(sub));

      const dlBtn = document.createElement('button');
      dlBtn.className = 'btn btn-outline btn-sm';
      dlBtn.textContent = 'Download PGN';
      dlBtn.addEventListener('click', () => downloadPgn(sub.id, sub.label));

      const delBtn = document.createElement('button');
      delBtn.className = 'sub-action-btn sub-action-delete';
      delBtn.textContent = 'Delete';
      delBtn.addEventListener('click', () => deleteSub(sub.id));

      actions.appendChild(editBtn);
      actions.appendChild(dlBtn);
      actions.appendChild(delBtn);

      card.appendChild(actions);
      list.appendChild(card);
    }
  }

  // ── Edit subscription ──────────────────────────────────────────────

  let editingSubId: number | null = null;

  function editSub(sub: any) {
    editingSubId = sub.id;
    const form = document.getElementById('add-form')!;
    const heading = form.querySelector('h2')!;
    const submitBtn = form.querySelector('button[type="submit"]')! as HTMLButtonElement;

    heading.textContent = 'Edit Subscription';
    submitBtn.textContent = 'Save Changes';
    form.style.display = 'block';

    // Pre-fill label
    (document.getElementById('dash-sub-label') as HTMLInputElement).value = sub.label || '';

    // Pre-fill exclude checkbox
    (document.getElementById('dash-sub-exclude-chess-com') as HTMLInputElement).checked = !!sub.exclude_site;

    // Reset filters and add the ones from the subscription
    dashActiveFilters.clear();
    dashContainer.innerHTML = '';

    const filterKeys = ['fen', 'player', 'eco', 'min_elo', 'max_elo', 'event'];
    for (const key of filterKeys) {
      if (sub[key]) {
        dashAddFilter(key);
        const inputId = `dash-sub-${key.replace('_', '-')}`;
        const input = document.getElementById(inputId) as HTMLInputElement | null;
        if (input) input.value = String(sub[key]);
      }
    }
  }

  function resetFormToCreate() {
    editingSubId = null;
    const form = document.getElementById('add-form')!;
    const heading = form.querySelector('h2')!;
    const submitBtn = form.querySelector('button[type="submit"]')! as HTMLButtonElement;
    heading.textContent = 'New Subscription';
    submitBtn.textContent = 'Create Subscription';
    (document.getElementById('sub-form') as HTMLFormElement).reset();
    dashActiveFilters.clear();
    dashContainer.innerHTML = '';
    dashAddFilter('fen');
  }

  // ── Download PGN ──────────────────────────────────────────────────

  async function downloadPgn(id: number, label: string) {
    try {
      const res = await fetch(`${API}/api/subscriptions/${id}/pgn`, { headers: authHeaders() });
      if (!res.ok) {
        const data = await res.json().catch(() => ({}));
        alert(data.detail || 'No games available for download yet.');
        return;
      }
      const blob = await res.blob();
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `${(label || 'subscription').replace(/\s+/g, '_')}.pgn`;
      document.body.appendChild(a);
      a.click();
      a.remove();
      URL.revokeObjectURL(url);
    } catch {
      alert('Could not download PGN. Try again later.');
    }
  }

  // ── Delete subscription ──────────────────────────────────────────

  async function deleteSub(id: number) {
    if (!confirm('Delete this subscription?')) return;
    try {
      await fetch(`${API}/api/subscriptions/${id}`, { method: 'DELETE', headers: authHeaders() });
      const res = await fetch(`${API}/api/subscriptions`, { headers: authHeaders() });
      const data = await res.json();
      renderSubscriptions(data.subscriptions);
    } catch {
      alert('Failed to delete subscription.');
    }
  }

  // ── Add/Edit form ──────────────────────────────────────────────────

  document.getElementById('show-add-form')!.addEventListener('click', () => {
    resetFormToCreate();
    document.getElementById('add-form')!.style.display = 'block';
  });

  document.getElementById('cancel-add')!.addEventListener('click', () => {
    document.getElementById('add-form')!.style.display = 'none';
    resetFormToCreate();
  });

  document.getElementById('sub-form')!.addEventListener('submit', async (e) => {
    e.preventDefault();
    const alertEl = document.getElementById('add-alert')!;

    const safeVal = (id: string) => {
      const el = document.getElementById(id) as HTMLInputElement | null;
      return el ? el.value.trim() || undefined : undefined;
    };
    const safeNumVal = (id: string) => {
      const el = document.getElementById(id) as HTMLInputElement | null;
      if (!el) return undefined;
      const v = el.value.trim();
      return v ? parseInt(v) : undefined;
    };

    const excludeChessCom = (document.getElementById('dash-sub-exclude-chess-com') as HTMLInputElement).checked;

    const body: any = {
      label: safeVal('dash-sub-label') || '',
      fen: safeVal('dash-sub-fen'),
      player: safeVal('dash-sub-player'),
      eco: safeVal('dash-sub-eco'),
      min_elo: safeNumVal('dash-sub-min-elo'),
      max_elo: safeNumVal('dash-sub-max-elo'),
      event: safeVal('dash-sub-event'),
      exclude_site: excludeChessCom ? 'chess.com' : undefined,
    };

    try {
      // If editing, delete the old one first
      if (editingSubId !== null) {
        await fetch(`${API}/api/subscriptions/${editingSubId}`, {
          method: 'DELETE', headers: authHeaders(),
        });
      }

      const res = await fetch(`${API}/api/subscriptions`, {
        method: 'POST',
        headers: authHeaders({ 'Content-Type': 'application/json' }),
        body: JSON.stringify(body),
      });
      const data = await res.json();
      alertEl.style.display = 'block';
      if (res.ok) {
        alertEl.className = 'alert alert-success';
        alertEl.textContent = editingSubId ? 'Subscription updated!' : 'Subscription created!';
        resetFormToCreate();
        setTimeout(() => { document.getElementById('add-form')!.style.display = 'none'; alertEl.style.display = 'none'; }, 1200);
        const subsRes = await fetch(`${API}/api/subscriptions`, { headers: authHeaders() });
        const subsData = await subsRes.json();
        renderSubscriptions(subsData.subscriptions);
      } else {
        alertEl.className = 'alert alert-error';
        alertEl.textContent = data.detail || 'Failed to save subscription.';
      }
    } catch {
      alertEl.style.display = 'block';
      alertEl.className = 'alert alert-error';
      alertEl.textContent = 'Could not reach the server.';
    }
  });

  init();
</script>
