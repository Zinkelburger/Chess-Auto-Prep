---
import Base from '../layouts/Base.astro';
---
<Base title="Dashboard">
  <div id="auth-gate" style="text-align:center; padding:60px 0;">
    <h1>Loading dashboard...</h1>
    <p class="subtitle">Authenticating...</p>
  </div>

  <div id="dashboard" style="display:none;">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:32px;">
      <div>
        <h1>Your Subscriptions</h1>
        <p class="subtitle" style="margin-bottom:0;" id="user-email"></p>
      </div>
      <button class="btn btn-primary" id="show-add-form">+ New Subscription</button>
    </div>

    <!-- Add subscription form (hidden by default) -->
    <div id="add-form" class="card" style="display:none; margin-bottom:24px;">
      <h2>New Subscription</h2>
      <div id="add-alert" style="display:none;"></div>
      <form id="sub-form">
        <div class="form-row">
          <label for="dash-sub-label">Label</label>
          <input type="text" id="dash-sub-label" />
        </div>

        <!-- Dynamic filters section -->
        <div class="filters-section">
          <div class="filters-header">
            <span class="filters-title">Filters</span>
            <span class="filters-hint">At least one required</span>
          </div>
          <div id="dash-filters-container"></div>
          <div class="dash-add-filter-wrap">
            <button type="button" class="btn btn-outline btn-sm" id="dash-add-filter-btn">+ Add filter</button>
            <div id="dash-filter-menu" class="filter-menu" style="display:none;"></div>
          </div>
        </div>

        <div class="form-row" style="display:flex; align-items:end; padding-bottom:2px;">
          <label class="checkbox-label">
            <input type="checkbox" id="dash-sub-exclude-chess-com" checked />
            <span>Exclude online games (i.e. chess.com)</span>
          </label>
        </div>

        <div style="display:flex; gap:10px; margin-top:8px;">
          <button type="submit" class="btn btn-primary">Create Subscription</button>
          <button type="button" class="btn btn-outline" id="cancel-add">Cancel</button>
        </div>
      </form>
    </div>

    <!-- Subscription list -->
    <div id="subs-list"></div>

    <div id="empty-state" class="card" style="display:none; text-align:center; padding:48px;">
      <p style="font-size:1.2rem; margin-bottom:8px;">No subscriptions yet</p>
      <p style="color:var(--text-dim); font-size:0.9rem;">
        Click "+ New Subscription" to start tracking positions, players, or openings.
      </p>
    </div>
  </div>
</Base>

<script>
  const API = import.meta.env.PUBLIC_API_URL || 'http://localhost:8000';
  let authToken: string | null = null;

  function authHeaders(extra: Record<string, string> = {}): Record<string, string> {
    return { 'Authorization': `Bearer ${authToken}`, ...extra };
  }

  // ── Dynamic filter system ──────────────────────────────────────────────

  interface FilterDef {
    key: string;
    label: string;
    inputType: string;
    inputMode?: string;
    pattern?: string;
    mono?: boolean;
    repeatable?: boolean;
    hasBoardPreview?: boolean;
    hasEcoPicker?: boolean;
    tooltip?: string;
  }

  const FILTER_DEFS: FilterDef[] = [
    { key: 'fen', label: 'FEN', inputType: 'text', mono: true, hasBoardPreview: true, repeatable: true },
    { key: 'player', label: 'Player name', inputType: 'text' },
    { key: 'eco', label: 'ECO Code', inputType: 'text', hasEcoPicker: true },
    { key: 'min_elo', label: 'Minimum Elo', inputType: 'text', inputMode: 'numeric', pattern: '[0-9]*', tooltip: 'At least one player must be at or above this rating' },
    { key: 'max_elo', label: 'Maximum Elo', inputType: 'text', inputMode: 'numeric', pattern: '[0-9]*', tooltip: 'Both players must be at or below this rating' },
    { key: 'event', label: 'Event name', inputType: 'text' },
  ];

  const dashActiveFilters: Set<string> = new Set();
  let dashFenCounter = 0;
  const dashContainer = document.getElementById('dash-filters-container')!;
  const dashAddBtn = document.getElementById('dash-add-filter-btn')!;
  const dashFilterMenu = document.getElementById('dash-filter-menu')!;

  function dashBuildFilterRow(def: FilterDef, instanceId?: string): HTMLElement {
    const rowKey = instanceId || def.key;
    const row = document.createElement('div');
    row.className = 'filter-row';
    row.dataset.filterKey = rowKey;

    const body = document.createElement('div');
    body.className = 'filter-body';

    const inputSuffix = instanceId ? instanceId.replace('_', '-') : def.key.replace('_', '-');
    const lbl = document.createElement('label');
    lbl.setAttribute('for', `dash-sub-${inputSuffix}`);
    if (def.tooltip) {
      lbl.innerHTML = `${def.label} <span class="tooltip-trigger" title="${def.tooltip}">?</span>`;
    } else {
      lbl.textContent = def.label;
    }
    body.appendChild(lbl);

    const input = document.createElement('input');
    input.type = def.inputType;
    input.id = `dash-sub-${inputSuffix}`;
    if (def.mono) input.className = 'mono';
    if (def.inputMode) input.inputMode = def.inputMode;
    if (def.pattern) input.pattern = def.pattern;
    input.autocomplete = 'off';
    if (def.repeatable) input.dataset.filterType = def.key;
    body.appendChild(input);

    if (def.hasBoardPreview) {
      const board = document.createElement('div');
      board.id = `dash-fen-board-${inputSuffix}`;
      board.className = 'board-preview';
      body.appendChild(board);
      const err = document.createElement('div');
      err.id = `dash-fen-error-${inputSuffix}`;
      err.className = 'board-invalid';
      body.appendChild(err);
    }

    if (def.hasEcoPicker) {
      const browseBtn = document.createElement('button');
      browseBtn.type = 'button';
      browseBtn.className = 'eco-trigger-btn';
      browseBtn.textContent = 'Browse openings...';
      browseBtn.addEventListener('click', () => openEcoModal(input));
      body.appendChild(browseBtn);
    }

    row.appendChild(body);

    const removeBtn = document.createElement('button');
    removeBtn.type = 'button';
    removeBtn.className = 'filter-remove';
    removeBtn.innerHTML = '&times;';
    removeBtn.title = 'Remove filter';
    removeBtn.addEventListener('click', () => dashRemoveFilter(rowKey));
    row.appendChild(removeBtn);

    return row;
  }

  function dashAddFilter(key: string, prefillValue?: string): string {
    const def = FILTER_DEFS.find(d => d.key === key);
    if (!def) return '';

    let instanceId: string | undefined;
    if (def.repeatable) {
      instanceId = `${key}-${dashFenCounter++}`;
    } else {
      if (dashActiveFilters.has(key)) return key;
    }
    const rowKey = instanceId || key;
    dashActiveFilters.add(rowKey);

    const row = dashBuildFilterRow(def, instanceId);
    dashContainer.appendChild(row);

    if (def.hasBoardPreview && instanceId) {
      const inputSuffix = instanceId.replace('_', '-');
      const fenInput = document.getElementById(`dash-sub-${inputSuffix}`) as HTMLInputElement;
      const fenBoard = document.getElementById(`dash-fen-board-${inputSuffix}`)!;
      const fenError = document.getElementById(`dash-fen-error-${inputSuffix}`)!;
      fenInput.addEventListener('input', () => (window as any).renderBoardPreview(fenInput.value, fenBoard, fenError));
      if (prefillValue) {
        fenInput.value = prefillValue;
        (window as any).renderBoardPreview(prefillValue, fenBoard, fenError);
      }
    } else if (prefillValue) {
      const inputSuffix = instanceId ? instanceId.replace('_', '-') : key.replace('_', '-');
      const input = document.getElementById(`dash-sub-${inputSuffix}`) as HTMLInputElement | null;
      if (input) input.value = prefillValue;
    }

    dashUpdateMenuState();
    dashHideMenu();
    return rowKey;
  }

  function dashRemoveFilter(rowKey: string) {
    dashActiveFilters.delete(rowKey);
    const row = dashContainer.querySelector(`[data-filter-key="${rowKey}"]`);
    if (row) row.remove();
    dashUpdateMenuState();
  }

  function dashUpdateMenuState() {
    dashFilterMenu.innerHTML = '';
    let anyAvailable = false;
    for (const def of FILTER_DEFS) {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'filter-menu-item';
      btn.textContent = def.label;
      if (!def.repeatable && dashActiveFilters.has(def.key)) {
        btn.disabled = true;
      } else {
        anyAvailable = true;
        btn.addEventListener('click', () => dashAddFilter(def.key));
      }
      dashFilterMenu.appendChild(btn);
    }
    dashAddBtn.style.display = anyAvailable ? '' : 'none';
  }

  function dashShowMenu() { dashFilterMenu.style.display = 'block'; }
  function dashHideMenu() { dashFilterMenu.style.display = 'none'; }

  dashAddBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    if (dashFilterMenu.style.display === 'none') {
      dashUpdateMenuState();
      dashShowMenu();
    } else {
      dashHideMenu();
    }
  });

  document.addEventListener('click', (e) => {
    if (!(e.target as Element).closest('.dash-add-filter-wrap')) dashHideMenu();
  });

  dashAddFilter('fen');

  // ── Auth & init ──────────────────────────────────────────────────────

  async function init() {
    const gate = document.getElementById('auth-gate')!;
    const dash = document.getElementById('dashboard')!;
    const params = new URLSearchParams(window.location.search);
    const urlToken = params.get('token');

    if (urlToken) {
      try {
        const res = await fetch(`${API}/api/exchange-token`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ token: urlToken }),
        });
        if (res.ok) {
          const data = await res.json();
          localStorage.setItem('twic_auth_token', data.auth_token);
          authToken = data.auth_token;
          window.history.replaceState({}, '', '/dashboard');
        } else {
          window.history.replaceState({}, '', '/dashboard');
          localStorage.removeItem('twic_auth_token');
          gate.innerHTML = `
            <h1>Link expired</h1>
            <p class="subtitle">This login link has already been used or has expired.</p>
            <a href="/twic-notifications" class="btn btn-primary">Request a new login link</a>`;
          return;
        }
      } catch {
        gate.innerHTML = `
          <div class="alert alert-error">Could not reach the server. Try refreshing the page.</div>`;
        return;
      }
    } else {
      authToken = localStorage.getItem('twic_auth_token');
    }

    if (!authToken) {
      gate.innerHTML = `
        <h1>Not logged in</h1>
        <p class="subtitle">You need a login link to access the dashboard.</p>
        <a href="/twic-notifications" class="btn btn-primary">Go to TWIC Notifications</a>`;
      return;
    }

    try {
      const [subsRes, meRes] = await Promise.all([
        fetch(`${API}/api/subscriptions`, { headers: authHeaders() }),
        fetch(`${API}/api/me`, { headers: authHeaders() }),
      ]);
      if (!subsRes.ok) {
        localStorage.removeItem('twic_auth_token');
        gate.innerHTML = `
          <h1>Session expired</h1>
          <p class="subtitle">Your session has expired.</p>
          <a href="/twic-notifications" class="btn btn-primary">Get a new login link</a>`;
        return;
      }

      gate.style.display = 'none';
      dash.style.display = 'block';

      if (meRes.ok) {
        const meData = await meRes.json();
        document.getElementById('user-email')!.textContent = meData.email;
      }

      const data = await subsRes.json();
      renderSubscriptions(data.subscriptions);
    } catch {
      gate.innerHTML = `
        <div class="alert alert-error">Could not reach the server.</div>
        <a href="/" class="btn btn-primary">Go Home</a>`;
    }
  }

  function renderSubscriptions(subs: any[]) {
    const list = document.getElementById('subs-list')!;
    const empty = document.getElementById('empty-state')!;

    if (subs.length === 0) {
      list.innerHTML = '';
      empty.style.display = 'block';
      return;
    }

    empty.style.display = 'none';
    list.innerHTML = '';

    for (const sub of subs) {
      const card = document.createElement('div');
      card.className = 'card';

      const h3 = document.createElement('h3');
      h3.style.marginBottom = '8px';
      h3.textContent = sub.label || 'Untitled subscription';
      card.appendChild(h3);

      const tagsDiv = document.createElement('div');
      tagsDiv.style.cssText = 'display:flex; flex-direction:column; gap:4px; margin-bottom:12px;';
      const tagEntries: [string, string][] = [];
      const fens: string[] = sub.fens || (sub.fen ? [sub.fen] : []);
      if (fens.length === 1) {
        tagEntries.push(['FEN', fens[0]]);
      } else if (fens.length > 1) {
        for (let i = 0; i < fens.length; i++) {
          tagEntries.push([`FEN ${i + 1}`, fens[i]]);
        }
      }
      if (sub.player) tagEntries.push(['Player', sub.player]);
      if (sub.white) tagEntries.push(['White', sub.white]);
      if (sub.black) tagEntries.push(['Black', sub.black]);
      if (sub.eco) tagEntries.push(['ECO', sub.eco]);
      if (sub.min_elo) tagEntries.push(['Min Elo', String(sub.min_elo)]);
      if (sub.max_elo) tagEntries.push(['Max Elo', String(sub.max_elo)]);
      if (sub.event) tagEntries.push(['Event', sub.event]);
      for (const [label, val] of tagEntries) {
        const row = document.createElement('div');
        row.style.cssText = 'font-size:0.82rem; color:var(--text-dim); font-family:var(--mono);';
        row.innerHTML = `<span style="color:var(--text);font-weight:500;">${label}:</span> ${val}`;
        tagsDiv.appendChild(row);
      }
      card.appendChild(tagsDiv);

      const actions = document.createElement('div');
      actions.style.cssText = 'display:flex; gap:8px; align-items:center;';

      const editBtn = document.createElement('button');
      editBtn.className = 'sub-action-btn';
      editBtn.innerHTML = 'Edit &#9998;';
      editBtn.title = 'Edit subscription';
      editBtn.addEventListener('click', () => editSub(sub));

      const issuesDiv = document.createElement('div');
      issuesDiv.className = 'sub-issues';

      const recentIssues = sub.recent_issues || [];
      const latestScanned = sub.latest_twic_scanned;

      if (recentIssues.length > 0) {
        for (const issue of recentIssues) {
          const btn = document.createElement('button');
          btn.className = 'btn btn-outline btn-sm';
          btn.textContent = `TWIC #${issue.twic}: ${issue.games} game${issue.games !== 1 ? 's' : ''}`;
          btn.addEventListener('click', () => downloadPgn(sub.id, sub.label));
          issuesDiv.appendChild(btn);
        }
        if (latestScanned && (!recentIssues.length || recentIssues[0].twic < latestScanned)) {
          const noMatch = document.createElement('span');
          noMatch.className = 'sub-no-match';
          noMatch.textContent = `0 matched in TWIC #${latestScanned}`;
          issuesDiv.appendChild(noMatch);
        }
      } else if (latestScanned) {
        const noMatch = document.createElement('span');
        noMatch.className = 'sub-no-match';
        noMatch.textContent = `0 matched in TWIC #${latestScanned}`;
        issuesDiv.appendChild(noMatch);
      } else {
        const pending = document.createElement('span');
        pending.className = 'sub-no-match';
        pending.textContent = 'Waiting for first scan...';
        issuesDiv.appendChild(pending);
      }

      const delBtn = document.createElement('button');
      delBtn.className = 'sub-action-btn sub-action-delete';
      delBtn.innerHTML = 'Delete &#128465;';
      delBtn.addEventListener('click', () => deleteSub(sub.id));

      actions.appendChild(editBtn);
      actions.appendChild(issuesDiv);
      actions.appendChild(delBtn);

      card.appendChild(actions);
      list.appendChild(card);
    }
  }

  // ── Edit subscription ──────────────────────────────────────────────

  let editingSubId: number | null = null;

  function editSub(sub: any) {
    editingSubId = sub.id;
    const form = document.getElementById('add-form')!;
    const heading = form.querySelector('h2')!;
    const submitBtn = form.querySelector('button[type="submit"]')! as HTMLButtonElement;

    heading.textContent = 'Edit Subscription';
    submitBtn.textContent = 'Save Changes';
    form.style.display = 'block';

    // Pre-fill label
    (document.getElementById('dash-sub-label') as HTMLInputElement).value = sub.label || '';

    // Pre-fill exclude checkbox
    (document.getElementById('dash-sub-exclude-chess-com') as HTMLInputElement).checked = !!sub.exclude_site;

    dashActiveFilters.clear();
    dashFenCounter = 0;
    dashContainer.innerHTML = '';

    const fens: string[] = sub.fens || (sub.fen ? [sub.fen] : []);
    for (const fen of fens) {
      dashAddFilter('fen', fen);
    }

    const otherFilterKeys = ['player', 'eco', 'min_elo', 'max_elo', 'event'];
    for (const key of otherFilterKeys) {
      if (sub[key]) {
        dashAddFilter(key, String(sub[key]));
      }
    }
  }

  function resetFormToCreate() {
    editingSubId = null;
    const form = document.getElementById('add-form')!;
    const heading = form.querySelector('h2')!;
    const submitBtn = form.querySelector('button[type="submit"]')! as HTMLButtonElement;
    heading.textContent = 'New Subscription';
    submitBtn.textContent = 'Create Subscription';
    (document.getElementById('sub-form') as HTMLFormElement).reset();
    dashActiveFilters.clear();
    dashFenCounter = 0;
    dashContainer.innerHTML = '';
    dashAddFilter('fen');
  }

  // ── Download PGN ──────────────────────────────────────────────────

  async function downloadPgn(id: number, label: string) {
    try {
      const res = await fetch(`${API}/api/subscriptions/${id}/pgn`, { headers: authHeaders() });
      if (!res.ok) {
        const data = await res.json().catch(() => ({}));
        alert(data.detail || 'No games available for download yet.');
        return;
      }
      const blob = await res.blob();
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `${(label || 'subscription').replace(/\s+/g, '_')}.pgn`;
      document.body.appendChild(a);
      a.click();
      a.remove();
      URL.revokeObjectURL(url);
    } catch {
      alert('Could not download PGN. Try again later.');
    }
  }

  // ── Delete subscription ──────────────────────────────────────────

  async function deleteSub(id: number) {
    if (!confirm('Delete this subscription?')) return;
    try {
      await fetch(`${API}/api/subscriptions/${id}`, { method: 'DELETE', headers: authHeaders() });
      const res = await fetch(`${API}/api/subscriptions`, { headers: authHeaders() });
      const data = await res.json();
      renderSubscriptions(data.subscriptions);
    } catch {
      alert('Failed to delete subscription.');
    }
  }

  // ── Add/Edit form ──────────────────────────────────────────────────

  document.getElementById('show-add-form')!.addEventListener('click', () => {
    resetFormToCreate();
    document.getElementById('add-form')!.style.display = 'block';
  });

  document.getElementById('cancel-add')!.addEventListener('click', () => {
    document.getElementById('add-form')!.style.display = 'none';
    resetFormToCreate();
  });

  document.getElementById('sub-form')!.addEventListener('submit', async (e) => {
    e.preventDefault();
    const alertEl = document.getElementById('add-alert')!;

    const safeVal = (id: string) => {
      const el = document.getElementById(id) as HTMLInputElement | null;
      return el ? el.value.trim() || undefined : undefined;
    };
    const safeNumVal = (id: string) => {
      const el = document.getElementById(id) as HTMLInputElement | null;
      if (!el) return undefined;
      const v = el.value.trim();
      return v ? parseInt(v) : undefined;
    };

    const excludeChessCom = (document.getElementById('dash-sub-exclude-chess-com') as HTMLInputElement).checked;

    const fenInputs = dashContainer.querySelectorAll<HTMLInputElement>('input[data-filter-type="fen"]');
    const fenValues = Array.from(fenInputs).map(el => el.value.trim()).filter(Boolean);

    const body: any = {
      label: safeVal('dash-sub-label') || '',
      fen: fenValues.length > 0 ? fenValues : undefined,
      player: safeVal('dash-sub-player'),
      eco: safeVal('dash-sub-eco'),
      min_elo: safeNumVal('dash-sub-min-elo'),
      max_elo: safeNumVal('dash-sub-max-elo'),
      event: safeVal('dash-sub-event'),
      exclude_site: excludeChessCom ? 'chess.com' : undefined,
    };

    try {
      // If editing, delete the old one first
      if (editingSubId !== null) {
        await fetch(`${API}/api/subscriptions/${editingSubId}`, {
          method: 'DELETE', headers: authHeaders(),
        });
      }

      const res = await fetch(`${API}/api/subscriptions`, {
        method: 'POST',
        headers: authHeaders({ 'Content-Type': 'application/json' }),
        body: JSON.stringify(body),
      });
      const data = await res.json();
      alertEl.style.display = 'block';
      if (res.ok) {
        alertEl.className = 'alert alert-success';
        alertEl.textContent = editingSubId ? 'Subscription updated!' : 'Subscription created!';
        resetFormToCreate();
        setTimeout(() => { document.getElementById('add-form')!.style.display = 'none'; alertEl.style.display = 'none'; }, 1200);
        const subsRes = await fetch(`${API}/api/subscriptions`, { headers: authHeaders() });
        const subsData = await subsRes.json();
        renderSubscriptions(subsData.subscriptions);
      } else {
        alertEl.className = 'alert alert-error';
        alertEl.textContent = data.detail || 'Failed to save subscription.';
      }
    } catch {
      alertEl.style.display = 'block';
      alertEl.className = 'alert alert-error';
      alertEl.textContent = 'Could not reach the server.';
    }
  });

  // ── ECO Picker Modal ──────────────────────────────────────────────

  let ecoData: [string, string, string, string][] = [];
  let ecoLoaded = false;

  async function loadEcoData() {
    if (ecoLoaded) return;
    try {
      const res = await fetch('/eco.json');
      ecoData = await res.json();
      ecoLoaded = true;
    } catch { /* silently fail */ }
  }

  loadEcoData();

  function fuzzyMatch(entry: [string, string, string, string], query: string): boolean {
    const [code, name] = entry;
    const words = query.toLowerCase().split(/\s+/).filter(w => w.length > 0);
    const haystack = `${code} ${name}`.toLowerCase();
    return words.every(w => haystack.includes(w));
  }

  function lichessAnalysisUrl(pgn: string): string {
    return `https://lichess.org/analysis/pgn/${encodeURIComponent(pgn)}`;
  }

  function openEcoModal(targetInput: HTMLInputElement) {
    loadEcoData();

    const backdrop = document.createElement('div');
    backdrop.className = 'eco-modal-backdrop';

    const modal = document.createElement('div');
    modal.className = 'eco-modal';

    modal.innerHTML = `
      <div class="eco-modal-header">
        <h3>Select ECO Opening</h3>
        <button class="eco-modal-close" type="button">&times;</button>
      </div>
      <div class="eco-modal-search">
        <input type="text" placeholder="Search by code or name... e.g. B90, Sicilian, Najdorf" autocomplete="off" />
        <div class="eco-search-hint">Type to filter 3,300+ openings. Click to select, then confirm.</div>
      </div>
      <div class="eco-modal-list"></div>
      <div class="eco-modal-footer">
        <span class="eco-selected-count"></span>
        <div style="display:flex; gap:8px;">
          <button type="button" class="btn btn-outline btn-sm eco-modal-cancel">Cancel</button>
          <button type="button" class="btn btn-primary btn-sm eco-modal-confirm">Select</button>
        </div>
      </div>
    `;

    backdrop.appendChild(modal);
    document.body.appendChild(backdrop);

    const searchInput = modal.querySelector('.eco-modal-search input') as HTMLInputElement;
    const listEl = modal.querySelector('.eco-modal-list')!;
    const countEl = modal.querySelector('.eco-selected-count')!;
    const closeBtn = modal.querySelector('.eco-modal-close')!;
    const cancelBtn = modal.querySelector('.eco-modal-cancel')!;
    const confirmBtn = modal.querySelector('.eco-modal-confirm')!;

    let selectedCode = targetInput.value.trim().toUpperCase();

    function close() { backdrop.remove(); }

    closeBtn.addEventListener('click', close);
    cancelBtn.addEventListener('click', close);
    backdrop.addEventListener('click', (e) => {
      if (e.target === backdrop) close();
    });
    document.addEventListener('keydown', function escHandler(e) {
      if (e.key === 'Escape') { close(); document.removeEventListener('keydown', escHandler); }
    });

    confirmBtn.addEventListener('click', () => {
      if (selectedCode) {
        targetInput.value = selectedCode;
        targetInput.dispatchEvent(new Event('input'));
      }
      close();
    });

    function renderList(query: string) {
      const filtered = query
        ? ecoData.filter(e => fuzzyMatch(e, query)).slice(0, 100)
        : ecoData.slice(0, 100);

      if (filtered.length === 0) {
        listEl.innerHTML = '<div class="eco-no-results">No openings match your search</div>';
        return;
      }

      listEl.innerHTML = '';
      const frag = document.createDocumentFragment();
      for (const [code, name, pgn, fen] of filtered) {
        const item = document.createElement('div');
        item.className = 'eco-item' + (code === selectedCode ? ' selected' : '');

        const mainRow = document.createElement('div');
        mainRow.className = 'eco-item-main';
        mainRow.innerHTML = `
          <span class="eco-item-toggle">&#9654;</span>
          <span class="eco-item-code">${code}</span>
          <span class="eco-item-name">${name}</span>
          <span class="eco-item-check">&#10003;</span>
        `;

        const details = document.createElement('div');
        details.className = 'eco-item-details';
        details.innerHTML = `
          <div class="eco-item-moves">${pgn}</div>
          <div class="eco-item-board"></div>
          <a href="${lichessAnalysisUrl(pgn)}" target="_blank" rel="noopener" class="eco-lichess-btn">
            Analyze on Lichess &#8599;
          </a>
        `;

        item.appendChild(mainRow);
        item.appendChild(details);

        const toggle = mainRow.querySelector('.eco-item-toggle')!;

        function expandCollapse() {
          const expanded = item.classList.toggle('expanded');
          if (expanded) {
            toggle.innerHTML = '&#9660;';
            const boardEl = details.querySelector('.eco-item-board') as HTMLElement;
            if (!boardEl.hasChildNodes()) {
              (window as any).renderBoardPreview(fen, boardEl, null);
              boardEl.style.display = 'grid';
            }
          } else {
            toggle.innerHTML = '&#9654;';
          }
        }

        mainRow.addEventListener('click', () => {
          selectedCode = code;
          listEl.querySelectorAll('.eco-item.selected').forEach(el => el.classList.remove('selected'));
          item.classList.add('selected');
          updateCount();
          expandCollapse();
        });

        frag.appendChild(item);
      }
      listEl.appendChild(frag);

      const total = query ? ecoData.filter(e => fuzzyMatch(e, query)).length : ecoData.length;
      if (total > 100) {
        const more = document.createElement('div');
        more.className = 'eco-no-results';
        more.textContent = `Showing 100 of ${total} results — refine your search`;
        listEl.appendChild(more);
      }
    }

    function updateCount() {
      countEl.textContent = selectedCode ? `Selected: ${selectedCode}` : '';
    }

    let searchTimer: ReturnType<typeof setTimeout>;
    searchInput.addEventListener('input', () => {
      clearTimeout(searchTimer);
      searchTimer = setTimeout(() => renderList(searchInput.value.trim()), 150);
    });

    renderList('');
    updateCount();
    setTimeout(() => searchInput.focus(), 50);
  }

  init();
</script>
