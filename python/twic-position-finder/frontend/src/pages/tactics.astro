---
import Base from '../layouts/Base.astro';
---
<Base title="Tactics Trainer">
  <div id="tactics-app" x-data="tacticsApp()" x-init="init()">
    <!-- Setup panel -->
    <div class="tactics-panel" x-show="!training">
      <h1>Tactics Trainer</h1>
      <p class="subtitle" style="margin-bottom:0;">Generate puzzles from your own games.</p>

      <div class="card card-form" style="margin-top:24px;">
        <div class="form-grid">
          <div class="form-row">
            <label for="lichess-user">Lichess username</label>
            <input type="text" id="lichess-user"
                   x-model="lichessUser"
                   placeholder="username" />
          </div>
          <div class="form-row">
            <label for="chesscom-user">Chess.com username</label>
            <input type="text" id="chesscom-user"
                   x-model="chesscomUser"
                   placeholder="username" />
          </div>
        </div>
        <div class="num-games-row">
          <div class="form-row" style="margin-bottom:0; max-width:200px;">
            <label for="num-games">Number of games</label>
            <input type="text" inputmode="numeric" id="num-games"
                   x-model.number="numGames" />
          </div>
          <button class="settings-btn" @click="settingsOpen = true" title="Settings">⚙</button>
        </div>

        <button class="btn btn-primary" style="width:100%; margin-top:8px;"
                @click="loadTactics()"
                :disabled="loading">
          <span x-text="loading ? 'Loading...' : 'Load Tactics'"></span>
        </button>

        <div class="engine-note" x-show="engineLoading">
          Engine loading in background...
        </div>

        <div class="status-line"
             :class="{ 'status-error': statusType === 'error', 'status-success': statusType === 'success' }">
          <div class="spinner" x-show="loading"></div>
          <span x-text="status"></span>
        </div>

        <div class="tactics-found" x-show="loading && tacticsFound > 0">
          Found: <strong x-text="tacticsFound"></strong> tactics
        </div>
      </div>
    </div>

    <!-- Training panel -->
    <div x-show="training" x-cloak>
      <div class="training-bar">
        <button class="btn btn-outline btn-sm" @click="backToSetup()">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" style="vertical-align:-3px;">
            <path d="M19 12H5M12 19l-7-7 7-7"/>
          </svg>
          Back
        </button>
        <span class="training-counter" x-text="`${currentIndex + 1} / ${tactics.length}`"></span>
      </div>

      <div class="training-layout">
        <div class="board-col">
          <div id="board" class="tactics-board"></div>
        </div>

        <div class="info-col">
          <div class="card tactic-meta">
            <div class="game-players" x-text="`${currentTactic?.game_white} vs ${currentTactic?.game_black}`"></div>
            <div class="you-played" x-show="currentTactic?.user_move">
              You played: <span x-text="currentTactic?.user_move + currentTactic?.mistake_type"></span>
            </div>
          </div>

          <div class="feedback-area">
            <span x-show="message && !solved" x-text="message"></span>
            <span x-show="solved && !solutionShown" style="color:var(--accent);">Correct!</span>
            <span x-show="solutionShown" x-text="'Best: ' + getSolutionSan()"></span>
            <span x-show="!message && !solved && !solutionShown">Find the best move.</span>
          </div>

          <div class="controls-grid">
            <button class="btn btn-secondary"
                    @click="prevTactic()"
                    :disabled="currentIndex === 0">Prev</button>
            <button class="btn btn-secondary"
                    @click="showSolution()">Solution</button>
            <button class="btn btn-secondary"
                    @click="nextTactic()">Next</button>
          </div>

          <div class="controls-extra">
            <label class="checkbox-label auto-next-label">
              <input type="checkbox" x-model="autoNext" style="width:16px; height:16px;" />
              <span>Auto-next</span>
            </label>
            <a class="link-btn"
               :href="currentTactic?.game_url"
               target="_blank"
               x-show="currentTactic?.game_url">
              Original Game
            </a>
            <button class="link-btn"
                    @click="openAnalysis()"
                    x-show="currentTactic?.game_url">
              Analyze on Lichess
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Settings modal -->
    <div class="modal-overlay" x-show="settingsOpen" x-transition.opacity x-cloak @click.self="settingsOpen = false">
      <div class="card modal-card" @click.stop>
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:16px;">
          <h2 style="margin-bottom:0;">Settings</h2>
          <button class="settings-btn" @click="settingsOpen = false" style="font-size:1.2rem;">✕</button>
        </div>
        <div class="form-grid">
          <div class="form-row">
            <label>Analysis Depth</label>
            <input type="number" x-model.number="analysisDepth" min="1" max="25" style="text-align:center;" />
          </div>
          <div class="form-row">
            <label x-text="`Threads (${maxThreads} available)`">Threads</label>
            <input type="number" x-model.number="threads" min="1" :max="maxThreads" style="text-align:center;" />
          </div>
        </div>
        <div>
          <label style="margin-bottom:10px;">Time Controls</label>
          <div class="chip-row">
            <template x-for="tc in timeControls" :key="tc.id">
              <label class="chip" :class="{ 'chip-active': tc.enabled }">
                <input type="checkbox" x-model="tc.enabled" style="display:none;" />
                <span x-text="tc.name"></span>
              </label>
            </template>
          </div>
        </div>
      </div>
    </div>

  </div>
</Base>

<style>
  [x-cloak] { display: none !important; }

  .num-games-row {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
  }

  .settings-btn {
    font-size: 1.4rem;
    line-height: 1;
    background: none;
    border: none;
    color: var(--text-dim);
    cursor: pointer;
    padding: 6px;
    margin-bottom: 2px;
    border-radius: 4px;
    transition: color 0.15s;
  }
  .settings-btn:hover { color: var(--text); }

  /* ── Settings modal ──────────────────────────── */

  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.65);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    z-index: 100;
  }

  .modal-card {
    width: auto;
    min-width: 280px;
    max-width: 360px;
  }

  .engine-note {
    font-size: 0.82rem;
    color: var(--text-dim);
    margin-top: 8px;
    text-align: center;
  }

  .status-line {
    text-align: center;
    margin-top: 12px;
    font-size: 0.85rem;
    color: var(--text-dim);
    min-height: 1.5em;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }
  .status-error { color: var(--danger); }
  .status-success { color: var(--accent); }

  .spinner {
    width: 14px;
    height: 14px;
    border: 2px solid var(--border);
    border-top-color: var(--accent);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  .tactics-found {
    text-align: center;
    margin-top: 6px;
    font-size: 0.9rem;
    color: var(--accent);
  }

  /* ── Training ──────────────────────────────────── */

  .training-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
  }

  .training-counter {
    font-family: var(--mono);
    font-size: 0.9rem;
    color: var(--text-dim);
  }

  .training-layout {
    display: grid;
    grid-template-columns: minmax(280px, 440px) 1fr;
    gap: 24px;
    align-items: start;
  }

  @media (max-width: 720px) {
    .training-layout {
      grid-template-columns: 1fr;
    }
  }

  .board-col {
    width: 100%;
  }

  .tactics-board {
    width: 100%;
    aspect-ratio: 1;
    border-radius: 6px;
    overflow: hidden;
    box-shadow: 0 4px 16px rgba(0,0,0,0.4);
  }

  .info-col {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .tactic-meta {
    margin-bottom: 0;
    padding: 16px 20px;
  }

  .game-players {
    font-size: 0.9rem;
    color: var(--text-dim);
    margin-bottom: 4px;
  }

  .you-played {
    font-size: 0.9rem;
    color: var(--text-dim);
  }

  .feedback-area {
    text-align: center;
    padding: 10px;
    font-size: 0.95rem;
    color: var(--text-dim);
    min-height: 2em;
  }

  .controls-grid {
    display: flex;
    gap: 8px;
  }
  .controls-grid button { flex: 1; }

  .controls-extra {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    padding-top: 8px;
  }

  .auto-next-label {
    font-size: 0.82rem !important;
    color: #6b7189;
  }
  .auto-next-label input[type="checkbox"] {
    accent-color: #6b7189;
  }

  .link-btn {
    background: none;
    border: none;
    font-family: var(--sans);
    font-size: 0.82rem;
    color: var(--text-dim);
    cursor: pointer;
    text-decoration: none;
    transition: color 0.15s;
  }
  .link-btn:hover { color: var(--text); }

  .chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .chip {
    cursor: pointer;
  }

  .chip span {
    display: inline-block;
    padding: 5px 12px;
    background: var(--bg-input);
    border: 1px solid var(--border);
    border-radius: 20px;
    font-size: 0.82rem;
    color: var(--text-dim);
    transition: all 0.15s;
  }

  .chip:hover span {
    border-color: var(--text-dim);
  }

  .chip-active span {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
  }
</style>

<script>
  import Alpine from 'alpinejs';
  import { tacticsApp } from '../tactics/app.js';
  import { Chess } from '../tactics/chess.js';

  import 'chessground/assets/chessground.base.css';
  import 'chessground/assets/chessground.brown.css';
  import 'chessground/assets/chessground.cburnett.css';

  (window as any).Chess = Chess;

  document.addEventListener('DOMContentLoaded', () => {
    (window as any).Alpine = Alpine;
    Alpine.data('tacticsApp', tacticsApp);
    Alpine.start();
  });
</script>
