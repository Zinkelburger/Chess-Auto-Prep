---
import Base from '../layouts/Base.astro';
---
<Base title="Home">
  <div class="hero">
    <h1>Chess Auto Prep</h1>
    <p class="subtitle">Tools to sharpen your chess preparation.</p>
  </div>

  <div class="features">
    <a href="/twic-notifications" class="feature-card">
      <div class="feature-icon">
        <img src="/piece/wN.svg" alt="" width="48" height="48" />
      </div>
      <h2>TWIC Notifications</h2>
      <p>Get email notifications when games from <strong>The Week in Chess</strong> reach positions you care about. Filter by player, Elo, or ECO code.</p>
      <span class="feature-cta">Set up notifications &rarr;</span>
    </a>

    <a href="/tactics" class="feature-card">
      <div class="feature-icon">
        <img src="/piece/bQ.svg" alt="" width="48" height="48" />
      </div>
      <h2>Tactics Trainer</h2>
      <p>Generate puzzles from your own <strong>Lichess</strong> and <strong>Chess.com</strong> games. Stockfish runs in your browser to find the moves you missed.</p>
      <span class="feature-cta">Start training &rarr;</span>
    </a>
  </div>
</Base>

<style>
  .hero {
    text-align: center;
    padding: 48px 0 40px;
  }

  .hero h1 {
    font-size: 2.6rem;
    letter-spacing: -0.03em;
    margin-bottom: 12px;
  }

  .hero .subtitle {
    font-size: 1.15rem;
    margin-bottom: 0;
  }

  .features {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    max-width: 760px;
    margin: 0 auto;
  }

  @media (max-width: 640px) {
    .features { grid-template-columns: 1fr; }
    .hero { padding: 32px 0 28px; }
    .hero h1 { font-size: 2rem; }
  }

  .feature-card {
    display: flex;
    flex-direction: column;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 28px 24px;
    text-decoration: none;
    color: var(--text);
    transition: border-color 0.2s, transform 0.15s;
  }

  .feature-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  .feature-icon {
    margin-bottom: 16px;
  }

  .feature-card h2 {
    font-size: 1.25rem;
    margin-bottom: 10px;
  }

  .feature-card p {
    color: var(--text-dim);
    font-size: 0.92rem;
    line-height: 1.55;
    flex: 1;
  }

  .feature-card strong {
    color: var(--text);
    font-weight: 600;
  }

  .feature-cta {
    display: inline-block;
    margin-top: 16px;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--accent);
  }

  .feature-card:hover .feature-cta {
    color: var(--accent-hover);
  }
</style>
